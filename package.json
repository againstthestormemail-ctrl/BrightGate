{
  "name": "brightgate",
  "version": "1.6.8",
  "description": "BrightGate \u2014 Kid-Safe Desktop Launcher",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.brightgate.app",
    "productName": "BrightGate",
    "copyright": "Copyright \u00a9 2025 BrightGate",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BrightGate",
      "uninstallDisplayName": "BrightGate",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "browser-preload.js",
      "updater.js",
      "version.json",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "compression": "maximum",
    "asar": true
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {}
}